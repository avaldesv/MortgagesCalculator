# API port (Railway sets PORT)
PORT=3000

# Auth
JWT_SECRET=change-me-in-production
ADMIN_EMAIL=admin@mortgagecalc.app
ADMIN_PASSWORD=changeme123

# Comma-separated origins for CORS (staging web URL)
CORS_ORIGIN=http://localhost:4200

# --- Optional PostgreSQL (Prisma) ---
# If set, API uses Prisma instead of JSON files in data/
DATABASE_URL=postgresql://user:pass@host:5432/mortgagecalc

# Run migrations on container start (Railway staging/prod)
PRISMA_MIGRATE_ON_START=true

# --- US market listings (Straply — free tier 100 lookups/day) ---
# https://straply.com/dashboard
STRAPLY_API_KEY=
